# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication
API_KEY=test_key
ADMIN_KEY=admin_secret_key

# Upload Configuration
MAX_FILE_SIZE_MB=100
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/webm,audio/mp4,audio/ogg
UPLOAD_DIR=./uploads

# ML Service Configuration
ML_SERVICE_URL=http://localhost:8000
ML_TRANSCRIBE_PATH=/transcribe
ML_HEALTH_PATH=/health
ML_SERVICE_TOKEN=
ML_HEALTHCHECK_ENABLED=true

# Supabase Configuration
# Get these from your Supabase project dashboard:
# https://app.supabase.com -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Legacy Database (deprecated, use Supabase instead)
DB_PATH=./whisperself.db
